# ============================================================
# MemorialOS Monitor — Variaveis de Ambiente (EXEMPLO)
# Copie para .env e preencha com seus valores reais
# ============================================================

# WhatsApp via Evolution API
WHATSAPP_ENABLED=false
EVOLUTION_API_URL=https://sua-instancia-evolution.com
EVOLUTION_API_KEY=sua_chave_api_aqui
EVOLUTION_INSTANCE=memorialos

# Destinatarios WhatsApp (JSON array)
# Formato: [{"name":"Nome","number":"5511999999999","role":"superadmin"}]
WHATSAPP_RECIPIENTS=[]

# Token para proteger o endpoint HTTP de trigger manual
MONITOR_TRIGGER_TOKEN=gere_um_token_seguro_aqui
